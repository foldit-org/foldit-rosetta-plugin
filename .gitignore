# Prerequisites
*.d

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Linker files
*.ilk

# Debugger Files
*.pdb

# Compiled Dynamic libraries
*.so
*.dylib
*.dll
*.so.*

# Committed per-platform fallback binaries (vendored). These are the
# opt-out for `cargo xtask setup-plugins`, so re-include them despite the
# blanket shared-library ignores above.
!prebuilt/**

# Opt-in local build output (`cargo xtask setup-plugins`), shadows the
# vendored prebuilt binary at runtime. Never committed.
local/


# Fortran module files
*.mod
*.smod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app

# Build directories
build/
Build/
build-*/

# CMake generated files
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
install_manifest.txt
compile_commands.json

# Temporary files
*.tmp
*.log
*.bak
*.swp

# vcpkg
vcpkg_installed/

# debug information files
*.dwo

# test output & cache
Testing/
.cache/

# Foldit rosetta plugin: downloaded model weights (fetched, never committed)
assets/models

# Foldit rosetta plugin: UI panel build artifacts. Ignore the dist CONTENTS
# (not the dir itself) so the vendored entrypoint below can be re-included --
# git cannot re-include a file whose parent directory is excluded.
ui/node_modules/
ui/dist/*
# Vendored panel entrypoint, committed alongside the prebuilt binary.
!ui/dist/rama_map.mjs

# Foldit rosetta plugin: vendored Rosetta database (the committed fallback).
# Re-include the whole tree despite the generic *.pdb / *.lib / *.a / *.o
# patterns above, which would otherwise silently drop structure and rotamer
# files (e.g. spin-label .pdb rotamers, *.bbdep.rotamers.lib) and ship a
# runtime-broken database.
!assets/database/**
